# Core app
NODE_ENV=development
PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret
SITE_URL=http://localhost:5000

# Database (Supabase Postgres)
# DATABASE_URL is the primary connection string consumed by the server.
# The POSTGRES_* variables are auto-generated by the Supabase/Vercel integration
# and kept here for parity across environments (pooler + non-pooling).
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
POSTGRES_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
POSTGRES_PRISMA_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
POSTGRES_URL_NON_POOLING=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
POSTGRES_USER=postgres.your-project-ref
POSTGRES_HOST=aws-0-us-east-1.pooler.supabase.com
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=postgres

# Supabase auth / storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Bootstrap admin identity
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$10$replace-with-bcrypt-hash

# Protected cron endpoints / GitHub Actions
CRON_SECRET=replace-with-a-long-random-secret

# Blog autopost model access
BLOG_GEMINI_API_KEY=

# Optional provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Email (SMTP) — Phase 28 recurring booking reminders
# Set these to enable 48h reminder emails for recurring bookings.
# Without them, reminder emails are silently skipped (no crash).
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=no-reply@example.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Your Company <no-reply@example.com>"
