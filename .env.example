# Core app
NODE_ENV=development
PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret
SITE_URL=http://localhost:5000

# Database
# Local/dev can use DATABASE_URL only.
# Vercel/serverless should also define POSTGRES_URL (pooled Supabase connection).
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
POSTGRES_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Supabase auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Bootstrap admin identity
ADMIN_EMAIL=admin@example.com

# Protected cron endpoints / GitHub Actions
CRON_SECRET=replace-with-a-long-random-secret

# Blog autopost model access
BLOG_GEMINI_API_KEY=

# Optional provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
